# Copy this file to .env and fill in real values. .env is git-ignored.
# Generate the two secrets locally, for example:
#   N8N_ENCRYPTION_KEY:  openssl rand -hex 32
#   POSTGRES_PASSWORD:   openssl rand -hex 16

# --- Postgres ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace_with_a_strong_random_password
POSTGRES_DB=n8n

# --- n8n encryption key ---
# Must be set before n8n first starts and then kept constant forever.
# In queue mode it must be IDENTICAL on the main process and every worker,
# otherwise workers cannot decrypt stored credentials.
N8N_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32

# --- Execution mode ---
# regular = single node runs everything (default).
# queue   = main enqueues jobs to Redis, workers execute them.
#           Set this to queue and start with:  docker compose --profile queue up -d
EXECUTIONS_MODE=regular

# --- Host / timezone ---
N8N_HOST=localhost
GENERIC_TIMEZONE=Etc/UTC
TZ=Etc/UTC

# --- Owner account (OPTIONAL) ---
# n8n removed the old N8N_BASIC_AUTH_* variables. Security is now handled by
# built-in user management: you create an owner account in the UI on first
# launch. To pre-provision that owner from the environment instead, set the
# values below and N8N_INSTANCE_OWNER_MANAGED_BY_ENV=true. The password hash is
# a bcrypt hash, not the plaintext password.
# N8N_INSTANCE_OWNER_MANAGED_BY_ENV=true
# N8N_INSTANCE_OWNER_EMAIL=admin@example.com
# N8N_INSTANCE_OWNER_FIRST_NAME=Demo
# N8N_INSTANCE_OWNER_LAST_NAME=Admin
# N8N_INSTANCE_OWNER_PASSWORD_HASH=replace_with_bcrypt_hash
