    {
      "id": "n-summary",
      "name": "Summary digest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1520,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const rows = $('Merge Branches').all().map(i => i.json);\nconst byUrgency = {};\nconst byTeam = {};\nlet escalated = 0;\nfor (const r of rows) {\n  byUrgency[r.urgency] = (byUrgency[r.urgency] || 0) + 1;\n  byTeam[r.suggested_team] = (byTeam[r.suggested_team] || 0) + 1;\n  if (r.route === 'escalate') escalated++;\n}\nconst fmt = (o) => Object.entries(o).map(([k,v]) => k + '=' + v).join(', ');\nconst digest = 'Triaged ' + rows.length + ' tickets. ' + escalated + ' escalated now. Urgency [' + fmt(byUrgency) + ']. Teams [' + fmt(byTeam) + '].';\nreturn [{ json: {\n  total_tickets: rows.length,\n  escalated_now: escalated,\n  by_urgency: byUrgency,\n  by_team: byTeam,\n  digest: digest\n}}];"
      }
    }
