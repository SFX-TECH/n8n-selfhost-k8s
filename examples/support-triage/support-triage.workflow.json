{
  "name": "AI Support Triage",
  "nodes": [
    {
      "id": "n-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -260,
        300
      ],
      "parameters": {}
    },
    {
      "id": "n-generate",
      "name": "Generate sample tickets",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -40,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const schema = {\n  type: 'object',\n  properties: {\n    category: { type: 'string', enum: ['billing','technical','feature_request','how_to','account','other'] },\n    urgency: { type: 'string', enum: ['low','medium','high'] },\n    sentiment: { type: 'string', enum: ['positive','neutral','negative'] },\n    suggested_team: { type: 'string' },\n    draft_reply: { type: 'string' }\n  },\n  required: ['category','urgency','sentiment','suggested_team','draft_reply']\n};\nconst system = \"You are a customer support triage assistant. Read the support ticket and classify it. Choose the best category, an urgency of low, medium, or high, and a sentiment of positive, neutral, or negative. Suggest which team should handle it (for example billing, technical_support, product, or general_support). Then draft a short, professional first reply of two to three sentences. Use only the fields requested.\";\nconst tickets = [\n  { ticket_id: 'TCK-1001', subject: 'Charged twice this month', body: 'I was billed 49 dollars two times on my card for the same subscription. Please refund the duplicate charge, this is frustrating.' },\n  { ticket_id: 'TCK-1002', subject: 'Cancelling, the app keeps crashing', body: 'The app has crashed three times today and I lost my work. I am done, I want to cancel my plan and switch to a competitor.' },\n  { ticket_id: 'TCK-1003', subject: 'Idea: dark mode for reports', body: 'Love the product. It would be great if the reports dashboard had a dark mode option for late night work. Not urgent at all.' },\n  { ticket_id: 'TCK-1004', subject: 'How do I export to CSV', body: 'Quick question, where do I find the option to export my data to a CSV file? Thanks in advance.' }\n];\nreturn tickets.map(t => ({\n  json: {\n    ticket_id: t.ticket_id,\n    subject: t.subject,\n    body: t.body,\n    ollamaBody: {\n      model: 'qwen3:8b',\n      stream: false,\n      think: false,\n      options: { temperature: 0.1 },\n      messages: [\n        { role: 'system', content: system },\n        { role: 'user', content: 'Subject: ' + t.subject + '. Body: ' + t.body }\n      ],\n      format: schema\n    }\n  }\n}));"
      }
    },
    {
      "id": "n-http",
      "name": "AI classify (Ollama qwen3:8b)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        180,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/api/chat",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.ollamaBody) }}",
        "options": {
          "timeout": 120000,
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      }
    },
    {
      "id": "n-parse",
      "name": "Parse AI output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const tickets = $('Generate sample tickets').all();\nreturn $input.all().map((item, i) => {\n  let ai = {};\n  try { ai = JSON.parse(item.json.message.content); }\n  catch (e) { ai = { category:'other', urgency:'medium', sentiment:'neutral', suggested_team:'general_support', draft_reply:'Thanks for reaching out, we are looking into this and will follow up shortly.' }; }\n  const t = tickets[i].json;\n  return { json: {\n    ticket_id: t.ticket_id,\n    subject: t.subject,\n    body: t.body,\n    category: String(ai.category || 'other'),\n    urgency: String(ai.urgency || 'medium'),\n    sentiment: String(ai.sentiment || 'neutral'),\n    suggested_team: String(ai.suggested_team || 'general_support'),\n    draft_reply: String(ai.draft_reply || '')\n  }};\n});"
      }
    },
    {
      "id": "n-if",
      "name": "Urgent or negative?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        620,
        300
      ],
      "parameters": {
        "conditions": {
          "combinator": "or",
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-urgency",
              "leftValue": "={{ $json.urgency }}",
              "rightValue": "high",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "cond-sentiment",
              "leftValue": "={{ $json.sentiment }}",
              "rightValue": "negative",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      }
    },
